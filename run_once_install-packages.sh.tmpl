#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
# macOS ships bash 3.2; sdkman requires bash 4+. Re-exec with Homebrew bash if needed.
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  brew install bash
  exec /opt/homebrew/bin/bash "$0" "$@"
fi

set -e

brew install \
  eza bat ripgrep fd fzf zoxide jq \
  kubectl kubectx helm starship fnm \
  zsh-autosuggestions \
  zsh-syntax-highlighting \
  zsh-history-substring-search \
  zsh-completions \
  forgit \
  zsh-you-should-use

{{ if eq .machine "work" -}}
brew install glab
{{ else -}}
brew install gh bitwarden-cli
{{ end -}}

# sdkman requires Bash 4+ — macOS ships Bash 3.2, so use the Homebrew-installed bash
brew install bash

if [[ ! -d "$HOME/.sdkman" ]]; then
  curl -s "https://get.sdkman.io" | /opt/homebrew/bin/bash
fi

sdkman_config="$HOME/.sdkman/etc/config"
if [[ -f "$sdkman_config" ]] && grep -q 'sdkman_auto_env=false' "$sdkman_config"; then
  sed -i '' 's/sdkman_auto_env=false/sdkman_auto_env=true/' "$sdkman_config"
fi

# Fix zsh compinit "insecure directories" warning from Homebrew share permissions
chmod go-w '/opt/homebrew/share'
chmod -R go-w '/opt/homebrew/share/zsh'

# Install Java LTS versions (21 and 25) via sdkman — Temurin distribution
# Dynamically resolves the latest patch for each major so this stays current
source "$HOME/.sdkman/bin/sdkman-init.sh"
for major in 21 25; do
  id=$(sdk list java 2>/dev/null | grep -Eo "${major}\.[0-9.]+-tem" | head -1)
  [[ -n "$id" ]] && { SDKMAN_AUTO_ANSWER=true sdk install java "$id" || true; }
done
latest25=$(sdk list java 2>/dev/null | grep -Eo "25\.[0-9.]+-tem" | head -1)
[[ -n "$latest25" ]] && sdk default java "$latest25"

# Install Node LTS via fnm and set as default
eval "$(fnm env --shell bash)"
fnm install --lts
fnm default "$(fnm list | grep -Eo 'v[0-9]+\.[0-9]+\.[0-9]+' | sort -V | tail -1)"

{{ else if .isWSL -}}
# System packages (wslu provides wslview for opening URLs/files in Windows)
sudo apt-get update -qq
sudo apt-get install -y build-essential curl git wslu

# Homebrew for Linux — gives same tool versions as macOS; brew --prefix resolves correctly
if ! command -v brew &>/dev/null; then
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

brew install \
  eza bat ripgrep fd fzf zoxide jq \
  kubectl kubectx helm starship fnm \
  zsh-autosuggestions \
  zsh-syntax-highlighting \
  zsh-history-substring-search \
  zsh-completions \
  forgit \
  zsh-you-should-use \
  gh

if [[ ! -d "$HOME/.sdkman" ]]; then
  curl -s "https://get.sdkman.io" | bash
fi

sdkman_config="$HOME/.sdkman/etc/config"
if [[ -f "$sdkman_config" ]] && grep -q 'sdkman_auto_env=false' "$sdkman_config"; then
  sed -i 's/sdkman_auto_env=false/sdkman_auto_env=true/' "$sdkman_config"
fi

# Install Java LTS versions (21 and 25) via sdkman — Temurin distribution
source "$HOME/.sdkman/bin/sdkman-init.sh"
for major in 21 25; do
  id=$(sdk list java 2>/dev/null | grep -Eo "${major}\.[0-9.]+-tem" | head -1)
  [[ -n "$id" ]] && { SDKMAN_AUTO_ANSWER=true sdk install java "$id" || true; }
done
latest25=$(sdk list java 2>/dev/null | grep -Eo "25\.[0-9.]+-tem" | head -1)
[[ -n "$latest25" ]] && sdk default java "$latest25"

# Install Node LTS via fnm and set as default
eval "$(fnm env --shell bash)"
fnm install --lts
fnm default "$(fnm list | grep -Eo 'v[0-9]+\.[0-9]+\.[0-9]+' | sort -V | tail -1)"
{{ end -}}
