[user]
    name = Tyler Cash
    email = {{ .gitEmail }}

[init]
    defaultBranch = main

[pull]
    rebase = false

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[diff]
    colorMoved = default

[merge]
    conflictstyle = diff3
